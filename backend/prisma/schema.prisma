// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String       @unique
  passwordHash   String
  level          Int          @default(1)
  totalScore     Int          @default(0)
  currentStreak  Int          @default(0)
  fastestSolveTime Int?
  lastActiveDate DateTime?
  role           String       @default("student")
  createdAt      DateTime     @default(now())
  submissions    Submission[]
}

model Challenge {
  id                    String       @id @default(auto()) @map("_id") @db.ObjectId
  title                 String
  description           String       // Maps to problem_statement from prompt.txt
  difficulty            Int
  language              String
  rubric                String
  difficultyExplanation String?
  createdBy             String?      @db.ObjectId
  
  // New fields from prompt.txt specification
  topic                 String?
  problemStyle          String?      // Algorithmic, Real-world, Debugging, Code Completion, Optimization
  inputFormat           String?
  outputFormat          String?
  constraints           String?      // JSON array as string
  examples              String?      // JSON array of {input, output, explanation}
  starterCode           String?
  referenceSolution     String?
  timeComplexity        String?
  spaceComplexity       String?
  edgeCases             String?      // JSON array as string
  hints                 String?      // JSON array as string
  testCases             String?      // JSON array of {input, expected_output}
  
  submissions           Submission[]
}

model Submission {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  challengeId String    @db.ObjectId
  code        String
  aiFeedback  String?
  score       Int?
  language    String    @default("javascript")
  durationMs  Int?
  hintsUsed   Int       @default(0)
  submittedAt DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id])
}
